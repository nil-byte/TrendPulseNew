# 示例配置：请复制为 `backend/.env` 后在本机填写真实值。
# 仓库内只保留占位符或空值，切勿提交任何真实密钥。

# Reddit API
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=TrendPulse/1.0
# 可选：企业网络/代理环境可在这里配置 HTTPS 代理；留空则直接连接
REDDIT_HTTPS_PROXY=
# 可选：如果需要自定义 CA 证书链，请填写本机证书文件路径
REDDIT_SSL_CA_FILE=
# asyncpraw 单次 HTTP 超时（秒）；走代理或并发采集时可适当调大，默认 45
# 须在进程启动前生效；后端 main 模块会在加载路由前写入 PRAWCORE_TIMEOUT
REDDIT_HTTP_TIMEOUT=45

# YouTube API
YOUTUBE_API_KEY=

# Grok API (X data collection)
# 默认使用官方 xAI Grok；使用 New API 等自建网关时：
# - GROK_PROVIDER_MODE=openai_compatible
# - GROK_BASE_URL 必须为 OpenAI 兼容根路径，一般以 /v1 结尾（无尾斜杠也可），
#   例如 https://your-new-api.example/v1 —— SDK 会请求 .../v1/chat/completions
# - GROK_API_KEY 填该网关中为该渠道配置的访问密钥（或令牌），与官方 xAI Key 不同
# - GROK_MODEL 须与网关中配置的模型名一致（如 grok-4、grok-3 等）
# - 部分 New API 部署在未指定 stream 时默认 SSE；适配器已固定 stream=false，无需额外配置
GROK_PROVIDER_MODE=official_xai
GROK_API_KEY=<YOUR_XAI_API_KEY_HERE>
GROK_BASE_URL=https://api.x.ai/v1
GROK_MODEL=grok-4.20-reasoning

# LLM Analysis API (OpenAI SDK compatible)
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=false
# 浏览器本地联调用的额外 CORS 白名单，多个值用英文逗号分隔；留空则仅允许 localhost/127.0.0.1 任意端口
CORS_ALLOWED_ORIGINS=
# 如需覆盖默认本地联调正则，可显式提供；默认允许 http(s)://localhost[:port] 与 127.0.0.1[:port]
CORS_ALLOWED_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1)(:\d+)?$

# 是否启动后台调度器（订阅周期任务等）。本地跑测试或仅调试 HTTP 时可设为 false
SCHEDULER_ENABLED=true

# 数据库（默认本机 SQLite；生产可改为带 async 驱动的 URL）
DATABASE_URL=sqlite+aiosqlite:///./trendpulse.db

# 各采集源统一使用的「最近 N 小时」时间窗（1–168）
COLLECTION_RECENCY_HOURS=24

# Grok 单次 HTTP 超时（秒）；与代码中 validation_alias GROK_HTTP_TIMEOUT 对应
GROK_HTTP_TIMEOUT=45

# X（Grok）批处理与容错：批量大小、并发批次数、重试与冷却；边界见 settings.py
X_BATCH_SIZE=20
X_PARALLEL_BATCHES=1
X_RETRY_MAX_ATTEMPTS=2
X_RETRY_BASE_DELAY_SECONDS=1.0
X_FAILURE_THRESHOLD=2
X_COOLDOWN_SECONDS=180
