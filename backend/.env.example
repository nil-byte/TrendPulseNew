# 示例配置：请复制为 `backend/.env` 后在本机填写真实值。
# 仓库内只保留占位符或空值，切勿提交任何真实密钥。

# Reddit API
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=TrendPulse/1.0

# YouTube API
YOUTUBE_API_KEY=

# Grok API (X data collection)
GROK_API_KEY=<YOUR_XAI_API_KEY_HERE>
GROK_BASE_URL=https://api.x.ai/v1
GROK_MODEL=grok-4.20-reasoning

# LLM Analysis API (OpenAI SDK compatible)
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true

# 是否启动后台调度器（订阅周期任务等）。本地跑测试或仅调试 HTTP 时可设为 false
SCHEDULER_ENABLED=true
