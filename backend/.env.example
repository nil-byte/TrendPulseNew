# Reddit API
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=TrendPulse/1.0

# YouTube API
YOUTUBE_API_KEY=

# Grok API (X data collection)
GROK_API_KEY=
GROK_BASE_URL=https://wududu.edu.kg/v1
GROK_MODEL=grok-4.20-beta

# LLM Analysis API (OpenAI SDK compatible)
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true

# 是否启动后台调度器（订阅周期任务等）。本地跑测试或仅调试 HTTP 时可设为 false
SCHEDULER_ENABLED=true
